#!/usr/bin/env bash
# setup-repo — first-time setup wizard for your Flatpak repository.
#
# Checks prerequisites, generates a GPG signing key, and populates
# repo.flatpakrepo — all in one command.
#
# Usage: bin/setup-repo

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Helpers ────────────────────────────────────────────────────────────────────

ok()   { echo "  ✓  $*"; }
fail() { echo "  ✗  $*" >&2; exit 1; }

prompt() {
  local prompt_text="$1"
  local default="${2:-}"
  local value
  if [[ -n "${default}" ]]; then
    read -r -p "  ${prompt_text} [${default}]: " value
    echo "${value:-${default}}"
  else
    while [[ -z "${value:-}" ]]; do
      read -r -p "  ${prompt_text}: " value
    done
    echo "${value}"
  fi
}

# ── Welcome ────────────────────────────────────────────────────────────────────

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Flatpak Repository — first-time setup"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Prerequisite checks ────────────────────────────────────────────────────────

echo "Checking prerequisites..."
echo ""

for cmd in git gpg jq base64 skopeo; do
  if command -v "${cmd}" > /dev/null 2>&1; then
    ok "${cmd}"
  else
    fail "${cmd} is not installed or not on PATH"
  fi
done

echo ""

# Must run from the repository root
if [[ ! -d "apps" ]]; then
  fail "Run this script from the repository root (expected to find an apps/ directory)"
fi

# Must have a git remote configured
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  fail "Not inside a git repository"
fi

REMOTE_URL=$(git remote get-url origin 2>/dev/null || true)
if [[ -z "${REMOTE_URL}" ]]; then
  fail "No 'origin' remote configured. Push your repository to GitHub first:\n     git remote add origin https://github.com/YOUR_USERNAME/YOUR_REPO.git"
fi

if ! echo "${REMOTE_URL}" | grep -q "github.com"; then
  fail "Remote origin does not appear to be a GitHub repository: ${REMOTE_URL}"
fi

ok "git remote: ${REMOTE_URL}"
echo ""

# ── Collect key details ────────────────────────────────────────────────────────

echo "GPG signing key details:"
echo ""
KEY_NAME=$(prompt "Key name" "Flatpak Repo")
KEY_EMAIL=$(prompt "Key email" "flatpak@example.com")
echo ""

# ── Generate key + populate repo.flatpakrepo ──────────────────────────────────

"${SCRIPT_DIR}/create-keys" "${KEY_NAME}" "${KEY_EMAIL}"

# ── Next steps ────────────────────────────────────────────────────────────────

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Next steps"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  1. Add the four secrets printed above to GitHub:"
echo "     https://github.com/$(git remote get-url origin | sed -E 's|.*github\.com[:/]||; s|\.git$||')/settings/secrets/actions"
echo ""
echo "  2. Commit and push:"
echo "     git add repo.flatpakrepo"
echo "     git commit -m 'chore: initialise flatpak repository'"
echo "     git push"
echo ""
echo "  3. After the workflow completes, make the GHCR packages public:"
echo "     https://github.com/$(git remote get-url origin | sed -E 's|.*github\.com[:/]([^/]+).*|\1|')?tab=packages"
echo ""
echo "  4. Delete private.key from your machine:"
echo "     rm private.key"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
