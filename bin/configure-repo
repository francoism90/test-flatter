#!/usr/bin/env bash
# configure-repo — populate repo.flatpakrepo with your GitHub username and repo name.
#
# The values are read from the git remote URL automatically.
# If a value cannot be determined you will be prompted to enter it.
#
# Usage: bin/configure-repo [GPG_KEY_ID]
#   GPG_KEY_ID  (optional) The key ID printed by bin/create-keys.
#               If omitted you will be prompted.

set -euo pipefail

FLATPAKREPO="repo.flatpakrepo"

# ── Helpers ────────────────────────────────────────────────────────────────────

prompt() {
  local var_name="$1"
  local prompt_text="$2"
  local default="${3:-}"
  local value

  if [[ -n "${default}" ]]; then
    read -r -p "${prompt_text} [${default}]: " value
    echo "${value:-${default}}"
  else
    while [[ -z "${value:-}" ]]; do
      read -r -p "${prompt_text}: " value
    done
    echo "${value}"
  fi
}

# Parse owner and repo name from a git remote URL.
# Handles both SSH (git@github.com:owner/repo.git) and HTTPS formats.
parse_remote() {
  local url="$1"
  # Strip trailing .git
  url="${url%.git}"
  # SSH: git@github.com:owner/repo  →  owner/repo
  # HTTPS: https://github.com/owner/repo  →  owner/repo
  echo "${url}" | sed -E 's|.*[:/]([^/]+/[^/]+)$|\1|'
}

# ── Detect owner/repo from git remote ─────────────────────────────────────────

DETECTED_OWNER=""
DETECTED_REPO=""

if git rev-parse --git-dir > /dev/null 2>&1; then
  REMOTE_URL=$(git remote get-url origin 2>/dev/null || true)
  if [[ -n "${REMOTE_URL}" ]] && echo "${REMOTE_URL}" | grep -q "github.com"; then
    SLUG=$(parse_remote "${REMOTE_URL}")
    DETECTED_OWNER="${SLUG%%/*}"
    DETECTED_REPO="${SLUG##*/}"
  fi
fi

# ── Gather values ──────────────────────────────────────────────────────────────

echo ""
echo "Setting up ${FLATPAKREPO}"
echo ""

OWNER=$(prompt "GitHub username / organisation" "GitHub username or organisation" "${DETECTED_OWNER}")
REPO=$(prompt "Repository name" "Repository name" "${DETECTED_REPO}")
TITLE=$(prompt "Repository title" "Human-readable title for the repo" "My Flatpak Repository")
COMMENT=$(prompt "Short description" "One-line description" "Custom Flatpak apps")
OWNER_LC="${OWNER,,}"
REPO_LC="${REPO,,}"

# GPG key — accept from argument or prompt
if [[ -n "${1:-}" ]]; then
  KEY_ID="$1"
else
  KEY_ID=$(prompt "GPG key ID" "GPG key ID (from bin/create-keys, or leave blank to fill in later)" "")
fi

GPG_B64=""
if [[ -n "${KEY_ID}" ]]; then
  GPG_B64=$(gpg --export "${KEY_ID}" 2>/dev/null | base64 --wrap=0 2>/dev/null || true)
  if [[ -z "${GPG_B64}" ]]; then
    echo "  Warning: could not export key '${KEY_ID}' — GPGKey will be left as a placeholder."
  fi
fi

# ── Write repo.flatpakrepo ─────────────────────────────────────────────────────

GPG_LINE="${GPG_B64:-PASTE_BASE64_BINARY_PUBLIC_KEY_HERE}"

cat > "${FLATPAKREPO}" <<EOF
[Flatpak Repo]
Title=${TITLE}
Url=oci+https://ghcr.io/${OWNER_LC}/${REPO_LC}/
Homepage=https://github.com/${OWNER}/${REPO}
Comment=${COMMENT}
Description=A self-hosted Flatpak repository serving OCI images from the GitHub Container Registry. Add this remote and receive automatic updates for all apps in the repository.
GPGKey=${GPG_LINE}
EOF

echo ""
echo "  Written ${FLATPAKREPO}:"
echo ""
cat "${FLATPAKREPO}"
echo ""

if [[ "${GPG_LINE}" == "PASTE_BASE64_BINARY_PUBLIC_KEY_HERE" ]]; then
  echo "  ⚠  GPGKey is still a placeholder."
  echo "     Run bin/create-keys first, then re-run:"
  echo "     bin/configure-repo YOUR_KEY_ID"
  echo ""
fi
